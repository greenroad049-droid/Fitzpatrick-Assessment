# Copia este archivo como .streamlit/secrets.toml (en local)
# o pégalo en "Settings > Secrets" dentro de Streamlit Cloud.
# NUNCA subas el archivo secrets.toml real a GitHub.

sheet_id = "PON_AQUI_EL_ID_DE_TU_GOOGLE_SHEET"
admin_password = "elige-una-contraseña-segura"

[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "...@...iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
